# Copy to `.env` (gitignored) and fill in. NEVER commit real values.

# --- UCL HPC connection (SGE cluster) ---
HPC_USER=your_username
HPC_GATEWAY=tails.cs.ucl.ac.uk            # SSH ProxyJump gateway (UCL CS)
HPC_LOGIN=peacock.cs.ucl.ac.uk            # SGE submit/login host
HPC_REMOTE_PROJECT=/home/your_username/cs_cluster_work   # where qsub runs (.o files land here)
HPC_RUN_HOME=/home/your_username/volume-set-mtpp         # where run scripts cd + write experiments/ and .last_<tag>_base
HPC_AUTH_MODE=password                    # password | key
# HPC_KEY=/path/to/id_ed25519             # only when HPC_AUTH_MODE=key
HPC_CONTROL_PERSIST=yes                   # keep the ControlMaster socket alive

# --- Experiment watcher / email-on-completion (Gmail app password, NOT your login password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465                             # 465 = SSL, 587 = STARTTLS
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password       # Google Account -> Security -> 2-Step -> App passwords
SMTP_TO=your_gmail@gmail.com
SMTP_FROM=your_gmail@gmail.com

# --- Watcher tunables (optional; defaults in watch_runs.sh) ---
WATCH_INTERVAL=90                         # seconds between polls (sane: 60-120)
WATCH_CRASH_GRACE=180                     # seconds after submit before "vanished from qstat" => crashed
WATCH_UNREACHABLE_ALERT_AFTER=10          # consecutive failed poll cycles before a cluster-unreachable alert
